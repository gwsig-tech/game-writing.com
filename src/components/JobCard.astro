---
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

interface Props {
  id: string;
  title: string;
  company: string;
  location: string;
  category: string;
  workType: string;
  experience: string;
  description: string;
  date: Date;
}

const {
  id,
  title,
  company,
  location,
  category,
  workType,
  experience,
  description,
  date,
} = Astro.props;
---

<li
  class="group relative -mx-4 flex flex-col items-start rounded-lg border-b border-border/50 px-4 py-8 transition-all hover:bg-foreground/5"
>
  <div class="flex w-full items-start justify-between gap-4">
    <div class="space-y-2">
      <div
        class="flex items-center gap-2 text-[10px] font-bold tracking-widest text-accent uppercase"
      >
        <span>{category}</span>
        <span class="text-border">•</span>
        <span>{company}</span>
      </div>

      <a
        href={`/jobs/${id}`}
        class="block transition-colors group-hover:text-accent"
      >
        <h2
          class="text-2xl font-bold text-foreground"
          style={{ viewTransitionName: slugifyStr(title) }}
        >
          {title}
        </h2>
      </a>

      <div
        class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-foreground/70"
      >
        <span class="flex items-center gap-1">📍 {location}</span>
        <span class="flex items-center gap-1">💼 {workType}</span>
        <span class="flex items-center gap-1">⏳ {experience}</span>
      </div>
    </div>

    <div class="hidden whitespace-nowrap sm:block">
      <Datetime pubDatetime={date} />
    </div>
  </div>

  <p class="mt-4 line-clamp-2 max-w-[70ch] leading-relaxed text-foreground/80">
    {description}
  </p>

  <div class="mt-4 sm:hidden">
    <Datetime pubDatetime={date} />
  </div>
</li>
