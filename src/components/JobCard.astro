---
interface Props {
  href: string;
  title: string;
  company: string;
  location?: string | null;
  workType?: string | null;
  remoteType?: string | null;
  experience?: string | null;
  description: string;
  date: Date;
  countries: string[];
  initiallyHidden?: boolean;
}

const {
  href,
  title,
  company,
  location,
  workType,
  remoteType,
  experience,
  description,
  date,
  countries,
  initiallyHidden = false,
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(date);

const employmentTerms: Record<string, RegExp> = {
  internship: /\b(?:internship|intern)\b/gi,
  freelance: /\bfreelance\b/gi,
  contract: /\bcontract\b/gi,
  temporary: /\btemporary\b/gi,
  "full-time": /\bfull[- ]time\b/gi,
  "part-time": /\bpart[- ]time\b/gi,
};

const employmentType = workType?.trim().toLowerCase();
const redundantTerm = employmentType ? employmentTerms[employmentType] : null;
const shortenedTitle = redundantTerm
  ? title
      .replace(redundantTerm, "")
      .replace(/\s+([,;:)])/g, "$1")
      .replace(/^[\s|/,:;–—-]+|[\s|/,:;–—-]+$/g, "")
      .replace(/\s{2,}/g, " ")
      .trim()
  : title;
const displayTitle = shortenedTitle || title;
---

<li
  class="job-card group relative border-b border-dashed transition-colors last:border-b-0"
  data-job-card
  data-countries={countries.join("|")}
  data-company={company.toLowerCase()}
  hidden={initiallyHidden}
>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${displayTitle} at ${company} (opens in a new tab)`}
    class="job-row-link block w-full px-2 py-7 sm:px-4"
  >
    <div class="flex w-full items-start justify-between gap-4">
      <div class="min-w-0 space-y-2">
        <p class="job-card-company leading-tight font-bold">{company}</p>

        <h2 class="job-card-title text-base leading-snug font-bold sm:text-lg">
          {displayTitle}
          <span class="text-sm font-normal" aria-hidden="true">↗</span>
        </h2>

        <div
          class="job-card-meta flex flex-wrap items-center gap-x-4 gap-y-1 text-sm"
        >
          {
            location && (
              <span class="flex items-center gap-1">📍 {location}</span>
            )
          }
          {
            remoteType && (
              <span class="flex items-center gap-1">🏠 {remoteType}</span>
            )
          }
          {
            workType && (
              <span class="flex items-center gap-1">💼 {workType}</span>
            )
          }
          {
            experience && (
              <span class="flex items-center gap-1">⏳ {experience}</span>
            )
          }
        </div>
      </div>

      <time
        class="job-card-date hidden text-xs font-medium whitespace-nowrap sm:block"
      >
        {formattedDate}
      </time>
    </div>

    {
      description && (
        <p class="job-card-description mt-4 line-clamp-2 max-w-[70ch] leading-relaxed">
          {description}
        </p>
      )
    }

    <div class="mt-4 sm:hidden">
      <time class="job-card-date text-xs font-medium">{formattedDate}</time>
    </div>
  </a>
</li>

<style>
  .job-card {
    border-color: var(--jobs-border, var(--border));
  }

  .job-card-company {
    color: var(--accent);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
  }

  .job-card-title {
    color: var(--jobs-ink, var(--foreground));
  }

  .job-card-meta,
  .job-card-description {
    color: var(--jobs-muted, var(--foreground));
  }

  .job-card-date {
    color: var(--jobs-subtle, var(--foreground));
  }
</style>
