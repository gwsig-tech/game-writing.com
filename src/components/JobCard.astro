---
import { slugifyStr } from "@/utils/slugify";

interface Props {
  id: string;
  title: string;
  company: string;
  location: string;
  category: string;
  workType: string;
  experience: string;
  description: string;
  date: string;
}

const { id, title, company, location, category, workType, experience, description, date } = Astro.props;
---

<li class="group relative flex flex-col items-start border-b border-border/50 py-8 transition-all hover:bg-slate-50/50 px-4 -mx-4 rounded-lg">
  <div class="flex w-full justify-between items-start gap-4">
    <div class="space-y-2">
      <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-accent">
        <span>{category}</span>
        <span class="text-border">•</span>
        <span>{company}</span>
      </div>

      <a href={`/jobs/${id}`} class="block group-hover:text-accent transition-colors">
        <h2 
          class="text-2xl font-bold text-slate-900" 
          style={{ viewTransitionName: slugifyStr(title) }}
        >
          {title}
        </h2>
      </a>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-slate-600">
        <span class="flex items-center gap-1">📍 {location}</span>
        <span class="flex items-center gap-1">💼 {workType}</span>
        <span class="flex items-center gap-1">⏳ {experience}</span>
      </div>
    </div>

    <time class="hidden sm:block text-xs font-medium text-slate-400 whitespace-nowrap">
      {date}
    </time>
  </div>

  <p class="mt-4 text-slate-700 leading-relaxed line-clamp-2 max-w-[70ch]">
    {description}
  </p>

  <div class="mt-4 sm:hidden">
     <time class="text-xs font-medium text-slate-400">{date}</time>
  </div>
</li>