---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import LinkButton from "../../components/LinkButton.astro";
import Datetime from "../../components/Datetime.astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import { slugifyStr } from "../../utils/slugify";

export async function getStaticPaths() {
  const jobEntries = await getCollection("jobs");

  return jobEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"jobs">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title,
  company,
  location,
  category,
  workType,
  experience,
  datePosted,
  applyLink,
} = entry.data;
---

<Layout title={`${title} | Jobs`}>
  <Header />

  <main id="main-content" class="mx-auto max-w-app px-4 py-12">
    <LinkButton
      href="/jobs"
      class="-ms-2 mb-8 text-sm hover:text-foreground/75"
    >
      <IconChevronLeft class="inline-block size-5 rtl:rotate-180" />
      <span>Back to Jobs</span>
    </LinkButton>

    <div class="border-b border-border pb-8">
      <div
        class="flex items-center gap-2 text-sm font-medium tracking-wider text-accent uppercase"
      >
        <span>{category}</span> • <span>{company}</span>
      </div>
      <h1
        class="mt-2 text-4xl font-bold text-foreground sm:text-5xl"
        style={{ viewTransitionName: slugifyStr(title) }}
      >
        {title}
      </h1>
      <p class="mt-4 text-xl text-foreground/90">{location}</p>

      <a
        href={applyLink}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-block rounded bg-accent px-8 py-3 font-semibold text-white transition-opacity hover:opacity-90"
      >
        Apply to {company}
      </a>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-3">
      <div class="app-prose md:col-span-2">
        <Content />
      </div>

      <aside
        class="h-fit rounded-lg border border-border bg-foreground/5 p-6 shadow-sm"
      >
        <h3 class="text-xs font-bold tracking-widest uppercase opacity-60">
          Job Details
        </h3>
        <dl class="mt-4 space-y-4">
          <div>
            <dt class="text-sm font-bold text-foreground">Experience</dt>
            <dd class="text-foreground/80">{experience}</dd>
          </div>
          <div>
            <dt class="text-sm font-bold text-foreground">Work Type</dt>
            <dd class="text-foreground/80">{workType}</dd>
          </div>
          <div>
            <dt class="text-sm font-bold text-foreground">Date Posted</dt>
            <dd class="mt-1">
              <Datetime pubDatetime={datePosted} />
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>
