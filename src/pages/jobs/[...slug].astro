---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { slugifyStr } from "../../utils/slugify";

export async function getStaticPaths() {
  const jobEntries = await getCollection("jobs");

  return jobEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"jobs">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, company, location, category, workType, experience, datePosted, applyLink } = entry.data;
---

<Layout title={`${title} | Jobs`}>
  <Header />
  
  <main id="main-content" class="mx-auto max-w-app px-4 py-12">
    <button 
      onclick="history.back()" 
      class="mb-8 flex items-center gap-2 text-sm opacity-60 hover:opacity-100 transition-opacity"
    >
      ← Back to Jobs
    </button>

    <div class="border-b border-border pb-8">
      <div class="flex items-center gap-2 text-accent font-medium uppercase tracking-wider text-sm">
        <span>{category}</span> • <span>{company}</span>
      </div>
      <h1 
        class="mt-2 text-4xl font-bold sm:text-5xl text-slate-900"
        style={{ viewTransitionName: slugifyStr(title) }}
      >
        {title}
      </h1>
      <p class="mt-4 text-xl text-slate-800">{location}</p>
      
      <a href={applyLink} 
         target="_blank"
         class="mt-6 inline-block bg-accent text-white px-8 py-3 font-semibold rounded hover:opacity-90 transition-opacity">
        Apply on {company}
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-12">
      <div class="md:col-span-2 space-y-8 job-content">
        <Content />
      </div>

      <aside class="bg-skin-fill border border-skin-line p-6 rounded-lg h-fit shadow-sm">
        <h3 class="font-bold uppercase text-xs tracking-widest opacity-60">Job Details</h3>
        <dl class="mt-4 space-y-4">
          <div>
            <dt class="text-sm font-bold text-slate-900">Experience</dt>
            <dd class="text-slate-800">{experience}</dd>
          </div>
          <div>
            <dt class="text-sm font-bold text-slate-900">Work Type</dt>
            <dd class="text-slate-800">{workType}</dd>
          </div>
          <div>
            <dt class="text-sm font-bold text-slate-900">Date Posted</dt>
            <dd class="text-slate-800">{datePosted}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* This ensures the Markdown output matches your design */
  .job-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .job-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: #1a1a1a;
  }
  .job-content ul {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .job-content li {
    margin-bottom: 0.5rem;
  }
</style>