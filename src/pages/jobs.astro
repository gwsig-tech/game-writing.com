---
import Layout from "@/layouts/Main.astro";
import { SITE } from "@/config";

// Load scraped postings JSON; tolerate missing/invalid file
let entries: Array<any> = [];
try {
  const data = await import("@/data/scraped-postings.json");
  entries = Array.isArray(data.default) ? data.default : [];
} catch (e) {
  entries = [];
}

// Newest first
entries = entries
  .slice()
  .sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());

const pageTitle = "Job Postings";
const pageDesc = "Curated job links shared by the IGDA Game Writing community.";
---

<Layout title={`${pageTitle} | ${SITE.title}`} description={pageDesc}>
  <section class="mx-auto max-w-app px-4 py-8">
    <h1 class="text-3xl font-semibold">Job Postings</h1>
    <p class="mt-2 text-muted-foreground">{pageDesc}</p>

    {entries.length === 0 ? (
      <p class="mt-8">No job postings yet.</p>
    ) : (
      <ul class="mt-8 space-y-6">
        {entries.map((e) => {
          const p = e.posting ?? {};
          const link = p.link as string | undefined;
          const poc = p.point_of_contact as string | undefined;
          const original = p.original_post as string | undefined;
          const ts = e.timestamp as string | undefined;
          const excerpt =
            (original ?? "")
              .replace(/\s+/g, " ")
              .slice(0, 220)
              .trim() + (original && original.length > 220 ? "…" : "");

          return (
            <li class="rounded-md border border-border p-4">
              <div class="flex flex-col gap-1">
                <div class="flex flex-wrap items-center gap-2">
                  {link ? (
                    <a href={link} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                      {link}
                    </a>
                  ) : (
                    <span class="text-muted-foreground">(no link)</span>
                  )}
                  {poc && <span class="text-sm text-muted-foreground">• {poc}</span>}
                  {ts && <time datetime={ts} class="text-sm text-muted-foreground">• {new Date(ts).toLocaleString()}</time>}
                </div>
                {excerpt && <p class="mt-2 text-sm leading-6">{excerpt}</p>}
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</Layout>

---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import scrapedPostingsData from "@/data/scraped-postings.json";

interface ScrapedPosting {
  timestamp: string;
  posting: {
    point_of_contact: string;
    original_post: string;
    link: string;
    years_of_exp?: string;
    location?: string;
    work_mode?: string;
  };
}

// Handle case where JSON might be empty or malformed
const postings: ScrapedPosting[] = Array.isArray(scrapedPostingsData) 
  ? scrapedPostingsData 
  : [];

// Sort by timestamp, newest first
const sortedPostings = [...postings].sort((a, b) => 
  new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime()
);

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function extractTitle(post: string): string {
  // Try to extract title from the post (usually first line before newline or pipe)
  const firstLine = post.split("\n")[0].trim();
  // Remove common LinkedIn post prefixes
  const cleaned = firstLine
    .replace(/^.*?\|.*?\|.*?\|\s*/, "") // Remove "Title | Author | Comments |"
    .replace(/\s*\|.*$/, "") // Remove trailing "| X comments"
    .trim();
  return cleaned || "Job Posting";
}

function formatPostingText(text: string): string {
  // Clean up the LinkedIn post text
  return text
    .replace(/\n{3,}/g, "\n\n") // Replace multiple newlines with double
    .trim();
}

const title = "Job Postings";
---

<Layout title={`${title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content">
    <section id="jobs" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{title}</h1>

      <p>Job postings shared in our community. Check back regularly for new opportunities!</p>

      <hr />

      {sortedPostings.length === 0 ? (
        <p>No job postings available at this time.</p>
      ) : (
        <div class="space-y-8">
          {sortedPostings.map((entry) => {
            const { posting } = entry;
            const jobTitle = extractTitle(posting.original_post);
            return (
              <article class="border-b border-border pb-6 last:border-b-0">
                <div class="mb-4">
                  <h2 class="text-xl font-semibold mb-2">
                    <a 
                      href={posting.link} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="hover:text-accent"
                    >
                      {jobTitle}
                    </a>
                  </h2>
                  <div class="text-sm text-muted flex flex-wrap gap-4 mb-3">
                    <span>Posted: {formatDate(entry.timestamp)}</span>
                    {posting.work_mode && (
                      <span class="font-medium">{posting.work_mode}</span>
                    )}
                    {posting.location && (
                      <span>📍 {posting.location}</span>
                    )}
                    {posting.years_of_exp && (
                      <span>💼 {posting.years_of_exp} years</span>
                    )}
                  </div>
                  {posting.point_of_contact && (
                    <div class="text-sm mb-3">
                      <strong>Contact:</strong>{" "}
                      {posting.point_of_contact.includes("@") ? (
                        <a 
                          href={`mailto:${posting.point_of_contact}`}
                          class="text-accent hover:underline"
                        >
                          {posting.point_of_contact}
                        </a>
                      ) : (
                        <span>{posting.point_of_contact}</span>
                      )}
                    </div>
                  )}
                </div>
                
                <div class="prose prose-sm max-w-none">
                  <p class="whitespace-pre-wrap text-muted">
                    {formatPostingText(posting.original_post)}
                  </p>
                </div>

                <div class="mt-4">
                  <a 
                    href={posting.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:underline text-sm font-medium"
                  >
                    View original post on LinkedIn →
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </section>
  </main>
  <Footer />
</Layout>
