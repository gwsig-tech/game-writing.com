---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JobCard from "../components/JobCard.astro";
import {
  getActiveJobs,
  getExperienceLabel,
  getJobCountries,
  getJobSummary,
} from "../lib/jobs";

const INITIAL_RESULTS = 20;
const jobs = await getActiveJobs();
const jobsWithCountries = jobs.map(job => ({
  job,
  countries: getJobCountries(job),
}));
const countryCounts = new Map<string, number>();
for (const { countries } of jobsWithCountries) {
  for (const country of countries) {
    countryCounts.set(country, (countryCounts.get(country) || 0) + 1);
  }
}
const countries = [...countryCounts.entries()].sort(([countryA], [countryB]) =>
  countryA.localeCompare(countryB)
);
const companyCounts = new Map<string, number>();
for (const job of jobs) {
  companyCounts.set(
    job.company_name,
    (companyCounts.get(job.company_name) || 0) + 1
  );
}
const companies = [...companyCounts.entries()].sort(([companyA], [companyB]) =>
  companyA.localeCompare(companyB)
);
---

<Layout title="Jobs | IGDA Game Writing SIG">
  <Header />
  <main class="jobs-page mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="jobs-paper relative overflow-visible rounded-lg border-2">
      <header
        class="jobs-section-border border-b border-dashed px-6 py-9 sm:px-10"
      >
        <p
          class="jobs-eyebrow mb-2 text-xs font-bold tracking-[0.24em] uppercase"
        >
          IGDA Game Writing SIG
        </p>
        <h1 class="jobs-heading text-4xl font-bold sm:text-5xl">Open Roles</h1>
        <p class="jobs-muted mt-3 max-w-2xl text-lg">
          Opportunities within the narrative and game writing space.
        </p>
        <p class="jobs-subtle mt-4 text-sm" aria-live="polite" id="jobs-count">
          Showing {Math.min(INITIAL_RESULTS, jobs.length)} of {jobs.length} active
          roles
        </p>
      </header>

      <div class="grid lg:grid-cols-[18rem_minmax(0,1fr)]">
        <aside
          class="jobs-section-border relative z-10 border-b border-dashed px-6 py-7 lg:border-r lg:border-b-0 lg:px-7"
        >
          <div class="lg:sticky lg:top-6">
            <h2
              class="jobs-heading text-[11px] font-bold tracking-[0.12em] uppercase"
            >
              Filter roles
            </h2>
            <details class="filter-picker mt-4">
              <summary>
                <span id="company-label">All companies</span>
                <span aria-hidden="true">⌄</span>
              </summary>
              <div class="filter-menu">
                <p>Select one or more companies</p>
                <div class="filter-options">
                  {
                    companies.map(([company, count]) => (
                      <label class="filter-option">
                        <input
                          type="checkbox"
                          name="company"
                          value={company.toLowerCase()}
                          data-label={company}
                        />
                        <span>{company}</span>
                        <small>{count}</small>
                      </label>
                    ))
                  }
                </div>
                <button type="button" class="clear-picker" id="clear-companies">
                  Clear companies
                </button>
              </div>
            </details>
            <details class="filter-picker mt-3">
              <summary>
                <span id="country-label">All countries</span>
                <span aria-hidden="true">⌄</span>
              </summary>
              <div class="filter-menu">
                <p>Select one or more countries</p>
                <div class="filter-options">
                  {
                    countries.map(([country, count]) => (
                      <label class="filter-option">
                        <input type="checkbox" name="country" value={country} />
                        <span>{country}</span>
                        <small>{count}</small>
                      </label>
                    ))
                  }
                </div>
                <button type="button" class="clear-picker" id="clear-countries">
                  Clear countries
                </button>
              </div>
            </details>
            <button type="button" id="clear-filters">Clear all filters</button>
          </div>
        </aside>

        <div class="min-w-0">
          <ul class="px-5 sm:px-8">
            {
              jobsWithCountries.map(({ job, countries }, index) => (
                <JobCard
                  href={job.canonical_url}
                  title={job.title}
                  company={job.company_name}
                  location={job.location}
                  workType={job.employment_type}
                  remoteType={job.remote_type}
                  experience={getExperienceLabel(job)}
                  date={job.first_seen_at}
                  description={getJobSummary(job)}
                  countries={countries}
                  initiallyHidden={index >= INITIAL_RESULTS}
                />
              ))
            }
          </ul>
          {
            jobs.length === 0 && (
              <p class="jobs-muted px-6 py-10 text-center">
                No active roles are listed right now. Check back soon.
              </p>
            )
          }
          <p
            id="no-filter-results"
            class="jobs-muted hidden px-6 py-12 text-center"
          >
            No active roles match those filters.
          </p>
          <div class="px-7 py-7 sm:px-10">
            <button
              type="button"
              id="load-more"
              hidden={jobs.length <= INITIAL_RESULTS}
            >
              Load more roles
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const countryFilters = document.querySelectorAll<HTMLInputElement>(
    'input[name="country"]'
  );
  const companyFilters = document.querySelectorAll<HTMLInputElement>(
    'input[name="company"]'
  );
  const cards = document.querySelectorAll<HTMLElement>("[data-job-card]");
  const count = document.querySelector<HTMLElement>("#jobs-count");
  const empty = document.querySelector<HTMLElement>("#no-filter-results");
  const loadMore = document.querySelector<HTMLButtonElement>("#load-more");
  const pickers =
    document.querySelectorAll<HTMLDetailsElement>(".filter-picker");

  const countryLabel = document.querySelector<HTMLElement>("#country-label");
  const companyLabel = document.querySelector<HTMLElement>("#company-label");
  const clearCountries =
    document.querySelector<HTMLButtonElement>("#clear-countries");
  const clearCompanies =
    document.querySelector<HTMLButtonElement>("#clear-companies");
  const clearFilters =
    document.querySelector<HTMLButtonElement>("#clear-filters");
  const pageSize = 20;
  let visibleLimit = pageSize;

  for (const picker of pickers) {
    picker.addEventListener("toggle", () => {
      if (!picker.open) return;
      for (const otherPicker of pickers) {
        if (otherPicker !== picker) otherPicker.open = false;
      }
    });
  }

  document.addEventListener("click", event => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (target.closest(".filter-picker")) return;
    for (const picker of pickers) picker.open = false;
  });

  function applyFilters(resetLimit = true) {
    if (resetLimit) visibleLimit = pageSize;
    const selectedCountries = [...countryFilters]
      .filter(filter => filter.checked)
      .map(filter => filter.value);
    const selectedCompanyFilters = [...companyFilters].filter(
      filter => filter.checked
    );
    const selectedCompanies = selectedCompanyFilters.map(
      filter => filter.value
    );
    const matches: HTMLElement[] = [];

    for (const card of cards) {
      const countries = card.dataset.countries?.split("|") || [];
      const matchesCountry =
        selectedCountries.length === 0 ||
        selectedCountries.some(country => countries.includes(country));
      const matchesCompany =
        selectedCompanies.length === 0 ||
        selectedCompanies.includes(card.dataset.company || "");
      if (matchesCountry && matchesCompany) matches.push(card);
    }

    for (const card of cards) card.hidden = true;
    for (const [index, card] of matches.entries()) {
      card.hidden = index >= visibleLimit;
    }

    const displayed = Math.min(visibleLimit, matches.length);

    if (countryLabel) {
      countryLabel.textContent =
        selectedCountries.length === 0
          ? "All countries"
          : selectedCountries.length === 1
            ? selectedCountries[0]
            : `${selectedCountries.length} countries`;
    }
    if (companyLabel) {
      companyLabel.textContent =
        selectedCompanyFilters.length === 0
          ? "All companies"
          : selectedCompanyFilters.length === 1
            ? selectedCompanyFilters[0].dataset.label || "1 company"
            : `${selectedCompanyFilters.length} companies`;
    }
    if (count) {
      count.textContent =
        displayed < matches.length
          ? `Showing ${displayed} of ${matches.length} active roles`
          : `Showing ${matches.length} active ${matches.length === 1 ? "role" : "roles"}`;
    }
    empty?.classList.toggle("hidden", matches.length !== 0);
    if (loadMore) loadMore.hidden = displayed >= matches.length;
  }

  for (const filter of [...countryFilters, ...companyFilters]) {
    filter.addEventListener("change", () => applyFilters());
  }

  clearCountries?.addEventListener("click", () => {
    for (const filter of countryFilters) filter.checked = false;
    applyFilters();
  });

  clearCompanies?.addEventListener("click", () => {
    for (const filter of companyFilters) filter.checked = false;
    applyFilters();
  });

  clearFilters?.addEventListener("click", () => {
    for (const filter of [...countryFilters, ...companyFilters]) {
      filter.checked = false;
    }
    applyFilters();
  });

  loadMore?.addEventListener("click", () => {
    visibleLimit += pageSize;
    applyFilters(false);
  });
</script>

<style>
  .jobs-page {
    --jobs-surface: var(--background);
    --jobs-ink: var(--foreground);
    --jobs-muted: color-mix(in srgb, var(--foreground) 72%, var(--background));
    --jobs-subtle: color-mix(in srgb, var(--foreground) 58%, var(--background));
    --jobs-border: color-mix(in srgb, var(--border) 72%, var(--background));
    --jobs-panel: color-mix(in srgb, var(--background) 88%, var(--foreground));
    --jobs-panel-strong: color-mix(
      in srgb,
      var(--background) 78%,
      var(--foreground)
    );
    --jobs-hover: color-mix(in srgb, var(--accent) 12%, transparent);
    --jobs-shadow: color-mix(in srgb, var(--foreground) 18%, transparent);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .jobs-paper {
    isolation: isolate;
    border-color: var(--jobs-border);
    background: var(--jobs-surface);
    box-shadow: 0 18px 50px var(--jobs-shadow);
    color: var(--jobs-ink);
  }

  .jobs-paper::after {
    position: absolute;
    z-index: -1;
    inset: 5px;
    border: 1px solid color-mix(in srgb, var(--jobs-border) 54%, transparent);
    border-radius: 0.35rem;
    content: "";
    pointer-events: none;
  }

  .jobs-section-border {
    border-color: var(--jobs-border);
  }

  .jobs-heading {
    color: var(--jobs-ink);
  }

  .jobs-eyebrow {
    color: var(--accent);
  }

  .jobs-muted {
    color: var(--jobs-muted);
  }

  .jobs-subtle {
    color: var(--jobs-subtle);
  }

  .filter-picker {
    position: relative;
  }

  .filter-picker summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-width: 0;
    width: 100%;
    border: 1.5px solid var(--jobs-border);
    border-radius: 0.45rem;
    background: var(--jobs-panel);
    padding: 0.65rem 0.75rem;
    color: var(--jobs-ink);
    cursor: pointer;
    list-style: none;
  }

  .filter-picker summary span:first-child {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .filter-picker summary::-webkit-details-marker {
    display: none;
  }

  .filter-picker[open] summary {
    box-shadow: 2px 3px 0 var(--jobs-shadow);
  }

  .filter-picker[open] summary span:last-child {
    transform: rotate(180deg);
  }

  .filter-menu {
    position: absolute;
    z-index: 20;
    left: 0;
    width: min(24rem, calc(100vw - 3rem));
    margin-top: 0.55rem;
    border: 1.5px dashed var(--jobs-border);
    border-radius: 0.45rem;
    background: var(--jobs-panel-strong);
    padding: 0.6rem;
    box-shadow: 0 1rem 2rem var(--jobs-shadow);
  }

  @media (min-width: 1024px) {
    .filter-menu {
      width: 24rem;
    }
  }

  .filter-menu > p {
    padding: 0.2rem 0.35rem 0.55rem;
    color: var(--jobs-subtle);
    font-size: 0.7rem;
  }

  .filter-options {
    max-height: 19rem;
    overflow-y: auto;
  }

  .filter-option {
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.55rem;
    border-radius: 0.2rem;
    padding: 0.4rem 0.45rem;
    color: var(--jobs-muted);
    cursor: pointer;
  }

  .filter-option:hover,
  .filter-option:has(input:checked) {
    background: var(--jobs-hover);
    color: var(--jobs-ink);
  }

  .filter-option input {
    accent-color: var(--accent);
  }

  .filter-option small {
    color: var(--jobs-subtle);
  }

  .clear-picker {
    width: 100%;
    margin-top: 0.5rem;
    border-top: 1px dashed var(--jobs-border);
    padding: 0.65rem 0.35rem 0.2rem;
    color: var(--accent);
    font-size: 0.75rem;
    text-align: left;
  }

  .clear-picker:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #clear-filters {
    margin-top: 1rem;
    color: var(--accent);
    font-size: 0.75rem;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 4px;
  }

  #load-more {
    width: 100%;
    border: 1.5px dashed var(--jobs-border);
    border-radius: 0.45rem;
    background: var(--jobs-panel);
    padding: 0.8rem 1rem;
    color: var(--jobs-ink);
    font-weight: 700;
  }

  #load-more:hover {
    background: var(--jobs-panel-strong);
  }

  :global(.job-card:hover) {
    background: var(--jobs-hover);
  }

  :global(.job-row-link:focus-visible) {
    background: var(--jobs-hover);
  }

  :global(.job-card[hidden]) {
    display: none;
  }
</style>
