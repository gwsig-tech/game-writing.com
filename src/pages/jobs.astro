---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JobCard from "../components/JobCard.astro";

// Example: Fetching from a collection named 'jobs'
// const allJobs = await getCollection("jobs");
---

<Layout title="Jobs | IGDA Game Writing SIG">
  <Header />
  <main class="mx-auto max-w-app px-4 py-12">
    <header class="mb-12 border-b border-border pb-8">
      <h1 class="text-4xl font-bold text-slate-900">Open Roles</h1>
      <p class="mt-2 text-lg text-slate-600">Opportunities within the narrative and game writing space.</p>
    </header>

    <ul class="space-y-2">
      <JobCard 
        id="principal-ux-writer-riftbound"
        title="Principal UX Writer - Riftbound"
        company="Riot Games"
        location="Mercer Island, USA (Hybrid)"
        category="Design"
        workType="Full-Time"
        experience="8+ Years"
        date="April 5, 2026"
        description="Craft the words that guide players through complex systems. You aren't just 'filling in the boxes'—you're designing the conversation between the game and the player."
      />
      
      </ul>
  </main>
  <Footer />
</Layout>