---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string; description?: string }>;

const { frontmatter } = Astro.props;
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description={frontmatter.description}
>
  <Header />
  <Breadcrumb />
  <main id="main-content">
    <section id="about" class="app-prose app-layout mb-28 prose-img:border-0">
      <h1 class="text-2xl font-semibold sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
